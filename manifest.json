{
  "manifest_version": 3,
  "name": "CF Highlighter",
  "version": "1.0.0",
  "description": "Highlight selected text and MathJax expressions on Codeforces pages.",
  "permissions": [
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://codeforces.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "highlight-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Highlight the current selection"
    }
  }
}
